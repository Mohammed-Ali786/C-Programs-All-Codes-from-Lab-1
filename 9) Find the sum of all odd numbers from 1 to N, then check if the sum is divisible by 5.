#include <stdio.h>
int main()
{
    int sum = 0;
    for (int i=1; i<=100; i++)
    {
        if (i%2!=0)
        {
            sum+=i;
        }
    }
    printf("sum =%d\n", sum);

    if (sum%5==0)
    {
        printf("Divisible by 5");
    }
    else
    {
        printf("Not divisible by 5");
    }
    return 0;
}
